{
  "name": "social-agent",
  "version": "1.0.0",
  "description": "Reddit -> OpenAI -> LinkedIn + Threads + X + Instagram + Facebook autoposter with DALL-E images and web dashboard.",
  "main": "src/agent.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "start": "tsx src/agent.ts",
    "start:pm2": "pm2 start npm --name social-agent --restart-delay=5000 -- start",
    "deploy": "bash scripts/deploy.sh",
    "fetch": "tsx src/cli.ts fetch",
    "queue": "tsx src/cli.ts queue",
    "status": "tsx src/cli.ts status",
    "memory": "tsx src/cli.ts memory",
    "history": "tsx src/cli.ts history",
    "post-now": "tsx src/cli.ts post-now",
    "test-meta": "tsx src/test-meta.ts",
    "test-x": "tsx src/test-x.ts"
  },
  "dependencies": {
    "node-cron": "^3.0.3",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^6.0.3"
  }
}
