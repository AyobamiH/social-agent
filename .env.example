# ----------------------------------------------------------------
# Social Agent - copy to .env and fill in your values
# .env is NEVER committed to GitHub
# ----------------------------------------------------------------

# Reddit
REDDIT_USER=advanced_pudding9228
REDDIT_ALLOWED_SUBS=openclawbot,lovablebuildershub
REDDIT_SORT=new
REDDIT_LIMIT=50

# OpenAI
# Used for text transforms and Instagram image generation
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
AI_STYLE=conversational
CUSTOM_PROMPT=

# LinkedIn
# Toggle LinkedIn on/off without removing credentials.
# Kept off in the tracked default profile until the merged slice is verified live in this repo.
ENABLE_LINKEDIN=false

# Required OAuth scope: w_member_social
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_TOKEN=

# Format: urn:li:person:XXXXXXXX
# Resolve with: curl -H "Authorization: Bearer YOUR_TOKEN" https://api.linkedin.com/v2/me
LINKEDIN_PERSON_URN=

# X / Twitter
# Toggle X on/off without removing credentials.
# v1 is text-only. Prefer OAuth 1.0a user-context credentials.
# A real OAuth 2.0 user access token is also supported as fallback.
# App-only bearer tokens and OAuth client secrets are not used by the posting runtime.
ENABLE_X=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_OAUTH2_ACCESS_TOKEN=

# Meta Platform
# One long-lived token covers Threads, Instagram and Facebook
# Get from: https://developers.facebook.com/tools/explorer
# Versions are configurable here if you need to bump Graph API paths later.
META_GRAPH_VERSION=v25.0
THREADS_GRAPH_VERSION=v25.0

# Toggle platforms on/off without removing credentials.
# Tracked default: Threads + Instagram.
# Leave Facebook off until the group permission issue is resolved.
ENABLE_THREADS=true
ENABLE_INSTAGRAM=true
ENABLE_FACEBOOK=false

# Required permissions:
#   threads_basic, threads_content_publish (for Threads)
#   instagram_basic, instagram_content_publish (for Instagram)
#   pages_read_engagement, pages_show_list (for Instagram with Facebook Login)
#   publish_to_groups, groups_access_member_info (for Facebook Group)
META_ACCESS_TOKEN=EAA...

# Optional: pin a Facebook Page access token for Instagram publishing.
# If blank, the app will try to derive it from FACEBOOK_PAGE_ID + META_ACCESS_TOKEN.
FACEBOOK_PAGE_ACCESS_TOKEN=

# Optional: use a dedicated Threads token if you have one.
# If blank, Threads falls back to META_ACCESS_TOKEN.
THREADS_ACCESS_TOKEN=

# Threads - your Threads user ID
# Get from: GET https://graph.threads.net/me?fields=id,username&access_token=TOKEN
THREADS_USER_ID=

# Instagram - your Instagram Professional account ID
# Optional if FACEBOOK_PAGE_ID is set and the Page is linked to the Instagram account.
# Get from: GET https://graph.facebook.com/v25.0/me/accounts?access_token=TOKEN
# Then: GET https://graph.facebook.com/v25.0/{page-id}?fields=instagram_business_account&access_token=TOKEN
# Do NOT put your Facebook user ID here.
INSTAGRAM_ACCOUNT_ID=

# Facebook - the Group ID you admin
# Find in the group URL: facebook.com/groups/GROUP_ID
FACEBOOK_GROUP_ID=

# Optional diagnostics from test-meta
FACEBOOK_USER_ID=
FACEBOOK_PAGE_ID=

# General
TIMEZONE=Europe/London
APP_DATA_DIR=

# Dashboard runs on port 4001 by default
GUI_PORT=4001

# Frontend origin(s) allowed to call the backend with credentials.
# Comma-separated. Leave blank for same-origin only.
# Production example: https://app.example.com
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base URL used for Stripe success/cancel redirects.
# Production example: https://app.example.com
FRONTEND_BASE_URL=http://localhost:3000

# Session and request hardening
# For HTTPS production, set COOKIE_SECURE=true.
# If frontend and backend are different sites, set COOKIE_SAME_SITE=None.
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
SESSION_TTL_DAYS=30
MAX_BODY_BYTES=1048576
TRUST_PROXY=false
BOOTSTRAP_MODE=localhost
BOOTSTRAP_TOKEN=
HTTP_TIMEOUT_MS=15000

# Optional: set your own 32-byte base64 key for secret encryption at rest.
# If left blank, the backend will generate and persist one in data/control-plane.key
APP_ENCRYPTION_KEY=

# Billing / Trial
TRIAL_DAYS=7

# Stripe Billing config for single-tenant subscription flow
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_GBP=
STRIPE_PRICE_YEARLY_GBP=
